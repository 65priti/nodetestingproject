<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>EduVerse - All Published Blogs</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body class="bg-light">

    <div class="d-flex">
        <div class="bg-dark text-white p-3 min-vh-100" style="width: 250px;">
            <h4 class="text-center text-warning mb-4">EduVerse Admin</h4>
            <ul class="nav flex-column gap-2">
                <li class="nav-item"><a href="/dashboard" class="nav-link text-white">📊 Dashboard</a></li>
                <li class="nav-item"><a href="/manage-tests" class="nav-link text-white">📝 Manage Tests</a></li>
                <li class="nav-item"><a href="/view-all-tests" class="nav-link text-white">📋 View All Tests</a></li>
                <li class="nav-item"><a href="/manage-blogs" class="nav-link text-white">✍️ Manage Blogs</a></li>
                <li class="nav-item"><a href="/view-all-blogs" class="nav-link text-white active fw-bold">📚 View All
                        Blogs</a></li>
                <li class="nav-item"><a href="/view-contacts-list" class="nav-link text-white">📞 View Messages</a></li>
            </ul>
        </div>

        <div class="flex-grow-1 p-4">
            <h2 class="mb-4 border-bottom pb-2">📚 All Published Blog Articles</h2>

            <div class="card p-3 shadow-sm border-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead class="table-dark">
                            <tr>
                                <th>#</th>
                                <th>Cover</th>
                                <th>Blog Title</th>
                                <th>Author</th>
                                <th>Published On</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if(blogs && blogs.length> 0) { %>
                                <% blogs.forEach((blog, index)=> { %>
                                    <tr>
                                        <td>
                                            <%= index + 1 %>
                                        </td>
                                        <td>
                                            <img src="<%= blog.image %>" alt="Cover" class="rounded"
                                                style="width: 50px; height: 40px; object-fit: cover;">
                                        </td>
                                        <td class="fw-bold text-dark">
                                            <%= blog.title %>
                                        </td>
                                        <td><span class="badge bg-info text-dark">
                                                <%= blog.author %>
                                            </span></td>
                                        <td>
                                            <%= new Date(blog.createdAt).toLocaleDateString('en-IN') %>
                                        </td>
                                        <td><a href="/manage-update-blogs/<%= blog.id %>">Edit</a>
                                            &nbsp;&nbsp;&nbsp;&nbsp; <button id="<%= blog.id %>" class="delete-btn"
                                                onclick="deleteFunction('<%= blog.id %>')">Delete</button></td>
                                    </tr>
                                    <% }) %>
                                        <% } else { %>
                                            <tr>
                                                <td colspan="5" class="text-center text-muted py-4">No blog articles
                                                    have been published yet.</td>
                                            </tr>
                                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>



    <script>
        function deleteFunction(id) {
            const confirmId = id && confirm("Are you sure you want to delete this blog?");
            if (confirmId) {
                fetch(`/admin-api/delete-blog/${id}`, {
                    method: "DELETE"
                }).then((response) => response.json()).then((response) => {
                    console.log(response.message)
                })
                console.log(id, 'id')
                window.location.reload()
            }

        }

    </script>

</body>

</html>