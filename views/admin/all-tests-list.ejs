<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>EduVerse - All Live Tests</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body class="bg-light">

    <div class="d-flex">
        <div class="bg-dark text-white p-3 min-vh-100" style="width: 250px;">
            <h4 class="text-center text-warning mb-4">EduVerse Admin</h4>
            <ul class="nav flex-column gap-2">
                <li class="nav-item"><a href="/admin-api/dashboard" class="nav-link text-white">📊 Dashboard</a></li>
                <li class="nav-item"><a href="/admin-api/manage-tests" class="nav-link text-white">➕ Add New Test</a>
                </li>
                <li class="nav-item"><a href="/admin-api/view-all-tests" class="nav-link text-white active fw-bold">📋
                        View All Tests</a></li>
                <li class="nav-item"><a href="/admin-api/manage-blogs" class="nav-link text-white">✍️ Manage Blogs</a>
                </li>
                <li class="nav-item"><a href="/admin-api/view-contacts-list" class="nav-link text-white">📞 View Messages</a>
                </li>
            </ul>
        </div>

        <div class="flex-grow-1 p-4">
            <h2 class="mb-4 border-bottom pb-2">📋 All Currently Live Test Series</h2>

            <div class="card p-3 shadow-sm border-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead class="table-dark">
                            <tr>
                                <th>#</th>
                                <th>Test Title</th>
                                <th>Type</th>
                                <th>Price</th>
                                <th>Total Questions</th>
                                <th>Created At</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if(tests && tests.length> 0) { %>
                                <% tests.forEach((test, index)=> { %>
                                    <tr>
                                        <td>
                                            <%= index + 1 %>
                                        </td>
                                        <td class="fw-bold text-primary">
                                            <%= test.title %>
                                        </td>
                                        <td>
                                            <span
                                                class="badge <%= test.testType === 'free' ? 'bg-success' : 'bg-danger' %> text-capitalize">
                                                <%= test.testType %>
                                            </span>
                                        </td>
                                        <td>
                                            <%= test.testType==='free' ? '₹0' : '₹' + test.price %>
                                        </td>
                                        <td><span class="badge bg-secondary">
                                                <%= test.questions ? test.questions.length : 0 %> Qs
                                            </span></td>
                                        <td>
                                            <%= new Date(test.createdAt).toLocaleDateString('en-IN') %>
                                        </td>
                                    </tr>
                                    <% }) %>
                                        <% } else { %>
                                            <tr>
                                                <td colspan="6" class="text-center text-muted py-4">Koi test series nahi
                                                    mili.</td>
                                            </tr>
                                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

</body>

</html>