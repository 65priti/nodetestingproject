<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>EduVerse - Admin Dashboard</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body class="bg-light">

    <div class="d-flex">
        <div class="bg-dark text-white p-3 min-vh-100" style="width: 250px;">
            <h4 class="text-center text-warning mb-4">EduVerse Admin</h4>
            <ul class="nav flex-column gap-2">
                <li class="nav-item">
                    <a href="/dashboard" class="nav-link text-white active fw-bold">📊 Dashboard</a>
                </li>
                <li class="nav-item">
                    <a href="/manage-tests" class="nav-link text-white">📝 Manage Tests</a>
                </li>
                <li class="nav-item">
                    <a href="/view-all-tests" class="nav-link text-white">📝 Manage Tests List</a>
                </li>
                <li class="nav-item">
                    <a href="/manage-blogs" class="nav-link text-white">✍️ Manage Blogs</a>
                </li>
                <li class="nav-item">
                    <a href="/view-contacts-list" class="nav-link text-white">📞 View Messages</a>
                </li>
                <li class="p-5" >
                    <form action="/admin-api/auth/logout" method="POST" style="display: inline;" >
                        <button type="submit" class="btn btn-danger btn-sm">
                             Logout
                        </button>
                    </form>
                </li>
            </ul>
        </div>

        <div class="flex-grow-1 p-4">
            <div class="d-flex justify-content-between align-items-center border-bottom pb-3 mb-4">
                <h2>Welcome to Control Panel Dashboard</h2>
                <span class="badge bg-success p-2">Server Status: Live 🟢</span>
            </div>

            <div class="row g-4">
                <div class="col-md-4">
                    <div class="card bg-primary text-white p-3 shadow-sm border-0">
                        <h5>📚 Total Test Series</h5>
                        <h2 class="mt-2">Live</h2>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card bg-info text-white p-3 shadow-sm border-0">
                        <h5>✍️ Dynamic Blogs</h5>
                        <h2 class="mt-2">Active</h2>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card bg-warning text-dark p-3 shadow-sm border-0">
                        <h5>📞 User Queries</h5>
                        <h2 class="mt-2">Messages</h2>
                    </div>
                </div>
            </div>
        </div>
    </div>

</body>

</html>