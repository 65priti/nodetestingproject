<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>EduVerse - Manage Tests</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">

    <div class="d-flex">
        <div class="bg-dark text-white p-3 min-vh-100" style="width: 250px;">
            <h4 class="text-center text-warning mb-4">EduVerse Admin</h4>
            <ul class="nav flex-column gap-2">
                <li class="nav-item"><a href="/admin-api/dashboard" class="nav-link text-white">📊 Dashboard</a></li>
                <li class="nav-item"><a href="/admin-api/manage-tests" class="nav-link text-white active fw-bold">📝 Manage Tests</a></li>
                <li class="nav-item"><a href="/admin-api/view-all-tests" class="nav-link text-white">📋 View All Tests</a></li>
                <li class="nav-item"><a href="/admin-api/manage-blogs" class="nav-link text-white">✍️ Manage Blogs</a></li>
                <li class="nav-item"><a href="/admin-api/view-all-blogs" class="nav-link text-white">📚 View All Blogs</a></li>
                <li class="nav-item"><a href="/admin-api/view-contacts-list" class="nav-link text-white">📞 View Messages</a></li>
            </ul>
        </div>

        <div class="flex-grow-1 p-4">
            <h2 class="mb-4 border-bottom pb-2">Create New Test Series</h2>

            <div class="card p-4 shadow-sm border-0">
                <form action="/admin-api/add-test" method="POST">
                    
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Test Title</label>
                            <input type="text" name="title" class="form-control" placeholder="e.g. Node.js Advanced Quiz" required>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label fw-bold">Test Type</label>
                            <select name="testType" class="form-select" required>
                                <option value="free">Free</option>
                                <option value="paid">Paid</option>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label fw-bold">Price (INR)</label>
                            <input type="number" name="price" class="form-control" value="0" min="0">
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-bold">Description</label>
                        <textarea name="description" class="form-control" rows="2" placeholder="Briefly describe what this test covers..."></textarea>
                    </div>

                    <hr>
                    <h4 class="text-primary mb-3"> Add Question 1</h4>

                    <div class="mb-3">
                        <label class="form-label">Question Text</label>
                        <input type="text" name="questions[0][questionText]" class="form-control" placeholder="e.g. What does HTML stand for?" required>
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label class="form-label">Option 1</label>
                            <input type="text" name="questions[0][options]" class="form-control" placeholder="Option 1" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Option 2</label>
                            <input type="text" name="questions[0][options]" class="form-control" placeholder="Option 2" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Option 3</label>
                            <input type="text" name="questions[0][options]" class="form-control" placeholder="Option 3" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Option 4</label>
                            <input type="text" name="questions[0][options]" class="form-control" placeholder="Option 4" required>
                        </div>
                    </div>

                    <div class="mb-4 col-md-4">
                        <label class="form-label fw-bold text-success">Correct Option Index (0 to 3)</label>
                        <input type="number" name="questions[0][correctOptionIndex]" class="form-control" min="0" max="3" placeholder="0 = Option 1, 1 = Option 2..." required>
                    </div>

                    <button type="submit" class="btn btn-warning fw-bold w-100 py-2">🚀 Publish Test Series Live</button>
                </form>
            </div>
        </div>
    </div>

</body>
</html>