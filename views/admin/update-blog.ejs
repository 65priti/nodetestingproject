<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Update EduVerse - Manage Blogs</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body class="bg-light">

    <div class="d-flex">
        <div class="bg-dark text-white p-3 min-vh-100" style="width: 250px;">
            <h4 class="text-center text-warning mb-4">EduVerse Admin</h4>
            <ul class="nav flex-column gap-2">
                <li class="nav-item"><a href="/dashboard" class="nav-link text-white">📊 Dashboard</a></li>
                <li class="nav-item"><a href="/manage-tests" class="nav-link text-white">📝 Manage Tests</a>
                </li>
                <li class="nav-item"><a href="/view-all-tests" class="nav-link text-white">📋 View All
                        Tests</a></li>
                <li class="nav-item"><a href="/manage-blogs" class="nav-link text-white active fw-bold">✍️
                        Manage Blogs</a></li>
                <li class="nav-item"><a href="/view-all-blogs" class="nav-link text-white">📚 View All
                        Blogs</a></li>
                <li class="nav-item"><a href="/view-contacts-list" class="nav-link text-white">📞 View
                        Messages</a></li>
            </ul>
        </div>

        <div class="flex-grow-1 p-4">
            <h2 class="mb-4 border-bottom pb-2">✍️ Edit Blog Post</h2>
            <div class="card p-4 shadow-sm border-0">
                <form action="/admin-api/update-blog/<%= blogData.id %>" method="POST">

                    <div class="row mb-3">
                        <div class="col-md-8">
                            <label class="form-label fw-bold">Blog Title</label>
                            <input type="text" name="title" class="form-control"
                                placeholder="e.g. Getting Started with Express.js" required value="<%= blogData.title %>" >
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-bold">Author Name</label>
                            <input type="text" name="author" class="form-control" placeholder="e.g. Admin or Your Name"
                                required  value="<%= blogData.author  %>" >
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Image URL / Path</label>
                        <input type="text" name="image" class="form-control" value="/images/default-blog.png"
                            placeholder="Set image path here...">
                        <small class="text-muted">Currently sending a simple text path. We will implement file uploads
                            using Multer later.</small>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-bold">Blog Content</label>
                        <textarea name="content" class="form-control" rows="6"
                            placeholder="Write your full article content here..." required  ><%= blogData.content %></textarea>
                    </div>

                    <button type="submit" class="btn btn-primary fw-bold w-100 py-2">📝 Publish Blog Article</button>
                </form>
            </div>
        </div>
    </div>

</body>

</html>

