<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>EduVerse - User Messages</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">

    <div class="d-flex">
        <div class="bg-dark text-white p-3 min-vh-100" style="width: 250px;">
            <h4 class="text-center text-warning mb-4">EduVerse Admin</h4>
            <ul class="nav flex-column gap-2">
                <li class="nav-item"><a href="/dashboard" class="nav-link text-white">📊 Dashboard</a></li>
                <li class="nav-item"><a href="/manage-tests" class="nav-link text-white">📝 Manage Tests</a></li>
                <li class="nav-item"><a href="/view-all-tests" class="nav-link text-white">📋 View All Tests</a></li>
                <li class="nav-item"><a href="/manage-blogs" class="nav-link text-white">✍️ Manage Blogs</a></li>
                <li class="nav-item"><a href="/view-all-blogs" class="nav-link text-white">📚 View All Blogs</a></li>
                <li class="nav-item"><a href="/view-contacts-list" class="nav-link text-white active fw-bold">📞 View Messages</a></li>
            </ul>
        </div>

        <div class="flex-grow-1 p-4">
            <h2 class="mb-4 border-bottom pb-2">📞 User Queries & Feedback Messages</h2>
            
            <div class="card p-3 shadow-sm border-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead class="table-dark">
                            <tr>
                                <th>#</th>
                                <th>User Name</th>
                                <th>Email Address</th>
                                <th>Message / Query</th>
                                <th>Received On</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if(contacts && contacts.length > 0) { %>
                                <% contacts.forEach((msg, index) => { %>
                                    <tr>
                                        <td><%= index + 1 %></td>
                                        <td class="fw-bold text-secondary"><%= msg.name %></td>
                                        <td><a href="mailto:<%= msg.email %>" class="text-decoration-none"><%= msg.email %></a></td>
                                        <td class="text-muted italic">"<%= msg.message %>"</td>
                                        <td><%= new Date(msg.createdAt).toLocaleString('en-IN', { dateStyle: 'short', timeStyle: 'short' }) %></td>
                                    </tr>
                                <% }) %>
                            <% } else { %>
                                <tr>
                                    <td colspan="5" class="text-center text-muted py-4">No user queries or messages have been received yet.</td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

</body>
</html>