<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body>
    <section class="w-100 p-5 d-flex flex-column align-items-center justify-content-between">
       <br><br>
        <div w-max-content>
            <h3 class="text-center mb-3">EduVerse Login</h3>
            <form action="/admin-api/login" method="POST" class="card p-5 shadow" style="max-width: 500px; min-width: 500px; margin: auto;">
                <div class="mb-3">
                    <label class="form-label">Email Address</label>
                    <input type="email" name="email" class="form-control" required>
                </div>

                <div class="mb-3">
                    <label class="form-label">Password</label>
                    <input type="password" name="password" class="form-control" required>
                </div>
<br><br>
                <button type="submit" class="btn btn-warning w-100">Sign In</button>
            </form>
        </div>
    </section>
</body>

</html>